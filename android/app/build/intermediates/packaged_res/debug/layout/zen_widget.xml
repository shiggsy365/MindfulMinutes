<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical">

    <!-- App label -->
    <TextView
        android:id="@+id/widget_app_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mindful Minutes"
        android:textColor="#7EFFFFFF"
        android:textSize="9sp"
        android:letterSpacing="0.12"
        android:textAllCaps="true"
        android:fontFamily="sans-serif"
        android:paddingBottom="6dp"/>

    <!-- Quote text -->
    <TextView
        android:id="@+id/widget_quote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="The quieter you become, the more you can hear."
        android:textColor="#F0FFFFFF"
        android:textSize="13sp"
        android:fontFamily="serif"
        android:textStyle="italic"
        android:lineSpacingMultiplier="1.3"
        android:maxLines="3"
        android:ellipsize="end"/>

    <!-- Divider -->
    <View
        android:layout_width="24dp"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#40FFFFFF"/>

    <!-- Intention label -->
    <TextView
        android:id="@+id/widget_intention_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TODAY'S INTENTION"
        android:textColor="#60FFFFFF"
        android:textSize="8sp"
        android:letterSpacing="0.15"
        android:textAllCaps="true"
        android:fontFamily="sans-serif"
        android:paddingBottom="4dp"/>

    <!-- Intention text -->
    <TextView
        android:id="@+id/widget_intention"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap to set your intention"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:fontFamily="sans-serif-light"
        android:maxLines="2"
        android:ellipsize="end"/>

</LinearLayout>
